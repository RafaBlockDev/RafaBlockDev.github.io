---
interface Props {
  id: string | number;
}

const { id } = Astro.props;
const toggleId = `sidenote-${id}`;
---

<span class="relative">
  <label
    for={toggleId}
    class="cursor-pointer align-super font-mono text-[0.65em] text-accent lg:cursor-default"
    aria-label={`Sidenote ${id}`}>[{id}]</label
  >
  <input type="checkbox" id={toggleId} class="peer sr-only" />

  <span
    class="mt-2 mb-4 hidden border-l-2 border-accent/40 pl-3 font-mono text-sm leading-snug text-ink/80 peer-checked:block lg:hidden!"
  >
    <slot />
  </span>

  <span
    class="hidden lg:relative lg:mt-0 lg:-mr-64 lg:block lg:w-56 lg:float-right lg:clear-right lg:border-l lg:border-accent/40 lg:pl-4 lg:font-mono lg:text-xs lg:leading-snug lg:text-ink/70"
  >
    <slot />
  </span>
</span>

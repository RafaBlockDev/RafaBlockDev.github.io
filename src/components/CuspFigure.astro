---
// Semicubical cusp 4a^3 + 27b^2 = 0, parametrized by (-3t^2, 2t^3) for
// t in [-1.15, 1.15]. Coordinates mirror the axis ranges of the source
// TikZ figure (a in [-4.2, 0.8], b in [-3.2, 3.2]) so the recreation
// matches the original one-to-one, just rendered as static SVG.
---

<figure class="not-prose my-8">
  <svg
    viewBox="0 0 460 320"
    class="mx-auto h-auto w-full max-w-xl"
    role="img"
    aria-labelledby="cusp-fig-title cusp-fig-desc"
  >
    <title id="cusp-fig-title">Discriminant curve in the (a, b) parameter plane</title>
    <desc id="cusp-fig-desc">
      Semicubical cusp in the (a,b) parameter plane separating the region with three
      distinct real roots from the regions with one real root.
    </desc>

    <!-- axes -->
    <line x1="30" y1="150" x2="448" y2="150" stroke="#1a1a1a" stroke-opacity="0.45" stroke-width="1" />
    <path d="M 448 150 L 440 146 L 440 154 Z" fill="#1a1a1a" fill-opacity="0.45" />
    <line x1="371.6" y1="8" x2="371.6" y2="300" stroke="#1a1a1a" stroke-opacity="0.45" stroke-width="1" />
    <path d="M 371.6 8 L 367.6 16 L 375.6 16 Z" fill="#1a1a1a" fill-opacity="0.45" />

    <!-- axis end labels -->
    <text x="436" y="141" font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace" font-size="13" fill="#1a1a1a" fill-opacity="0.7">a</text>
    <text x="378" y="20" font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace" font-size="13" fill="#1a1a1a" fill-opacity="0.7">b</text>

    <!-- a-axis ticks: -4, -3, -2, -1 -->
    <g stroke="#1a1a1a" stroke-opacity="0.45" stroke-width="1">
      <line x1="59.6" y1="146" x2="59.6" y2="154" />
      <line x1="137.6" y1="146" x2="137.6" y2="154" />
      <line x1="215.6" y1="146" x2="215.6" y2="154" />
      <line x1="293.6" y1="146" x2="293.6" y2="154" />
    </g>
    <g font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace" font-size="10.5" fill="#1a1a1a" fill-opacity="0.55" text-anchor="middle">
      <text x="59.6" y="167">-4</text>
      <text x="137.6" y="167">-3</text>
      <text x="215.6" y="167">-2</text>
      <text x="293.6" y="167">-1</text>
    </g>

    <!-- b-axis ticks: 2, -2 -->
    <g stroke="#1a1a1a" stroke-opacity="0.45" stroke-width="1">
      <line x1="367.6" y1="68.8" x2="375.6" y2="68.8" />
      <line x1="367.6" y1="231.2" x2="375.6" y2="231.2" />
    </g>
    <g font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace" font-size="10.5" fill="#1a1a1a" fill-opacity="0.55">
      <text x="381" y="72.5">2</text>
      <text x="381" y="235">-2</text>
    </g>

    <!-- cusp curve, delta = 0 -->
    <path
      d="M 371.6 150.0 L 371.1 150.0 L 369.8 149.9 L 367.5 149.8 L 364.3 149.6 L 360.2 149.1 L 355.1 148.5 L 349.2 147.6 L 342.3 146.4 L 334.5 144.9 L 325.8 143.0 L 316.2 140.6 L 305.7 137.9 L 294.2 134.6 L 281.9 130.7 L 268.6 126.3 L 254.4 121.2 L 239.3 115.5 L 223.3 109.0 L 206.3 101.8 L 188.5 93.8 L 169.7 84.9 L 150.0 75.1 L 129.4 64.5 L 107.9 52.8 L 85.5 40.1 L 62.1 26.4"
      fill="none"
      stroke="#003366"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <path
      d="M 371.6 150.0 L 371.1 150.0 L 369.8 150.1 L 367.5 150.2 L 364.3 150.4 L 360.2 150.9 L 355.1 151.5 L 349.2 152.4 L 342.3 153.6 L 334.5 155.1 L 325.8 157.0 L 316.2 159.4 L 305.7 162.1 L 294.2 165.4 L 281.9 169.3 L 268.6 173.7 L 254.4 178.8 L 239.3 184.5 L 223.3 191.0 L 206.3 198.2 L 188.5 206.2 L 169.7 215.1 L 150.0 224.9 L 129.4 235.5 L 107.9 247.2 L 85.5 259.9 L 62.1 273.6"
      fill="none"
      stroke="#003366"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <!-- cusp point at the origin -->
    <circle cx="371.6" cy="150" r="2.8" fill="#003366" />
    <text
      x="378"
      y="145"
      font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace"
      font-size="11"
      fill="#003366"
    >cusp</text>

    <!-- legend -->
    <line x1="52" y1="34" x2="72" y2="34" stroke="#003366" stroke-width="2.2" />
    <text
      x="78"
      y="38"
      font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace"
      font-size="12"
      fill="#1a1a1a"
      fill-opacity="0.75"
    >&#x394; = 0</text>

    <!-- region labels -->
    <g font-family="'JetBrains Mono','Fira Code',ui-monospace,monospace" font-size="12" fill="#1a1a1a" fill-opacity="0.75" text-anchor="middle">
      <text x="207.8" y="90">three real roots</text>
      <text x="293.6" y="46.4">one real root</text>
      <text x="293.6" y="257.6">one real root</text>
    </g>
  </svg>
  <figcaption class="mt-3 text-center font-mono text-xs text-ink/60">
    The discriminant curve divides parameter space into regions with different real-root
    behavior.
  </figcaption>
</figure>

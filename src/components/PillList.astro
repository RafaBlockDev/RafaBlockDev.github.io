---
interface Props {
  /** Pill labels; the list renders nothing when empty. */
  items: string[];
  /** Accessible label for the group, e.g. "Tags" or "Stack". */
  label: string;
  /** Wrapper margin utility, since callers space the list differently. */
  class?: string;
}

const { items, label, class: className = 'mt-2' } = Astro.props;
---

{
  items.length > 0 && (
    <ul class:list={[className, 'flex flex-wrap gap-2']} aria-label={label}>
      {items.map((item) => (
        <li class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">
          {item}
        </li>
      ))}
    </ul>
  )
}

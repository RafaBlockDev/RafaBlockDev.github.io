---
interface Props {
  /** Must be unique on the page; also used as the JSXGraph container id. */
  id: string;
  /** Accessible group label (not always shown visually). */
  title: string;
  /** Longer text for assistive tech, describing what the figure shows. */
  description: string;
  /** Visible caption under the figure. */
  caption: string;
  /** CSS aspect-ratio, e.g. "23 / 16". */
  aspectRatio?: string;
  /** True for boards with a keyboard/drag-operable point. */
  interactive?: boolean;
}

const { id, title, description, caption, aspectRatio = '23 / 16', interactive = false } = Astro.props;

const descId = `${id}-desc`;
---

<figure class="not-prose my-8">
  <div
    id={id}
    class="jxg-board mx-auto w-full max-w-xl rounded-sm border border-ink/10"
    style={`aspect-ratio: ${aspectRatio};`}
    role={interactive ? 'group' : 'img'}
    aria-label={title}
    aria-describedby={descId}
    tabindex={interactive ? 0 : undefined}
  >
  </div>
  <p id={descId} class="sr-only">{description}</p>
  <figcaption class="mt-3 text-center font-mono text-xs text-ink/60">{caption}</figcaption>
  <slot />
</figure>

<style>
  /* JSXGraph's own stylesheet isn't importable as a package subpath and its
     default chrome (rounded blue box, nav buttons) doesn't fit the site's
     restrained look, so only the functional minimum is replicated here. */
  .jxg-board {
    position: relative;
    overflow: hidden;
    background-color: transparent;
  }
  .jxg-board :global(text) {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    -webkit-user-select: none;
    user-select: none;
  }
  .jxg-board:focus-visible {
    outline: 2px solid #003366;
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .jxg-board :global(*) {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

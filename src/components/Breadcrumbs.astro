---
import { withBase } from '../lib/paths';

interface Crumb {
  href?: string;
  label: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="font-mono text-xs text-ink/60">
  <ol class="flex flex-wrap items-center gap-1">
    {
      crumbs.map((crumb, i) => (
        <li class="flex items-center gap-1">
          {i > 0 && <span aria-hidden="true">/</span>}
          {crumb.href ? (
            <a href={withBase(crumb.href)} class="hover:text-accent">
              {crumb.label}
            </a>
          ) : (
            <span aria-current="page" class="text-ink/80">
              {crumb.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

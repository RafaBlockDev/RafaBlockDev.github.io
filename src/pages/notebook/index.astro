---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('notebook')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<AcademicLayout title="Notebook — Research Notebook" description="Working notes and reading logs.">
  <h1 class="font-serif text-2xl font-normal text-ink">Notebook</h1>
  <p class="mt-2 max-w-2xl text-sm text-ink/60">
    Working notes, reading logs, and in-progress thinking, newest first.
  </p>

  <ol class="mt-10 max-w-2xl space-y-8">
    {
      entries.map((entry) => (
        <li class="border-b border-ink/10 pb-6 last:border-none">
          <a href={`/notebook/${entry.id}`} class="font-serif text-lg text-ink hover:text-accent">
            {entry.data.title}
          </a>
          <p class="mt-1 font-mono text-xs text-ink/50">
            {dateFormatter.format(entry.data.date)}
            {entry.data.updatedDate && <> &middot; updated {dateFormatter.format(entry.data.updatedDate)}</>}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-ink/80">{entry.data.summary}</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {entry.data.tags.map((tag) => (
              <span class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">{tag}</span>
            ))}
          </div>
        </li>
      ))
    }
    {entries.length === 0 && <p class="text-sm text-ink/50">No entries yet.</p>}
  </ol>
</AcademicLayout>

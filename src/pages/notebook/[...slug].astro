---
import 'katex/dist/katex.min.css';
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PillList from '../../components/PillList.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { SITE, dateFormatter } from '../../lib/site';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const entries = await getCollection('notebook', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'notebook'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Notebook', href: '/notebook/' },
  { label: data.title }
];

const pageUrl = new URL(Astro.url.pathname, SITE.url).href;
const jsonLd = [
  articleJsonLd({
    type: 'BlogPosting',
    title: data.title,
    description: data.summary,
    url: pageUrl,
    datePublished: data.date,
    dateModified: data.updatedDate
  }),
  breadcrumbJsonLd(crumbs)
];
---

<AcademicLayout
  title={`${data.title} · ${SITE.name}`}
  description={data.summary}
  ogType="article"
  ogImage={data.ogImage}
  publishedTime={data.date}
  modifiedTime={data.updatedDate}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-2xl">
    <Breadcrumbs crumbs={crumbs} />

    <header class="mt-6">
      <p class="font-mono text-xs uppercase tracking-wide text-accent">Notebook entry</p>
      <h1 class="mt-2 font-serif text-2xl font-normal leading-snug text-ink">{data.title}</h1>
      <p class="mt-2 font-mono text-xs text-ink/60">
        {dateFormatter.format(data.date)}
        {data.updatedDate && <> &middot; updated {dateFormatter.format(data.updatedDate)}</>}
      </p>
      <PillList items={data.tags} label="Tags" class="mt-3" />
    </header>

    <div class="prose-doc mt-8 max-w-none">
      <Content />
    </div>
  </article>
</AcademicLayout>

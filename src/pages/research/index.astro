---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/paths';
import { SITE, RESEARCH_STATUS_LABELS, dateFormatter } from '../../lib/site';
import { breadcrumbJsonLd } from '../../lib/jsonld';

const items = (await getCollection('research', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<AcademicLayout
  title={`Research · ${SITE.name}`}
  description="Papers, preprints, technical notes, and expository mathematical notes by Rafael Fuentes Rangel, with honest status labels."
  jsonLd={[breadcrumbJsonLd([{ label: 'Home', href: '/' }, { label: 'Research' }])]}
>
  <h1 class="font-serif text-2xl font-normal text-ink">Research</h1>
  <p class="mt-2 max-w-2xl text-sm text-ink/70">
    Formal and research-oriented work: papers, technical notes, and expository
    mathematical notes, newest first. Each entry states its actual publication
    status.
  </p>

  <ol class="mt-10 max-w-3xl space-y-10">
    {
      items.map((item, index) => (
        <li class="border-b border-ink/10 pb-8 last:border-none">
          <div class="flex items-start gap-3">
            <span class="mt-1 font-mono text-xs text-ink/60" aria-hidden="true">
              [{index + 1}]
            </span>
            <div class="flex-1">
              <h2 class="font-serif text-lg text-ink">
                <a href={withBase(`/research/${item.id}/`)} class="hover:text-accent">
                  {item.data.title}
                </a>
              </h2>
              <p class="mt-1 text-sm text-ink/70">{item.data.authors.join(', ')}</p>
              <p class="mt-1 font-mono text-xs text-ink/60">
                {RESEARCH_STATUS_LABELS[item.data.status]}
                {item.data.venue && <> &middot; {item.data.venue}</>}
                &middot; {dateFormatter.format(item.data.date)}
              </p>
              <p class="mt-2 text-sm leading-relaxed text-ink/80">{item.data.summary}</p>
              <p class="mt-3">
                <a
                  href={withBase(`/research/${item.id}/`)}
                  class="font-mono text-xs text-accent underline underline-offset-2 hover:text-ink"
                >
                  Details, abstract &amp; citation &rarr;
                </a>
              </p>
            </div>
          </div>
        </li>
      ))
    }
    {
      items.length === 0 && (
        <li class="max-w-2xl text-sm leading-relaxed text-ink/70">
          Research notes are being prepared for publication here. In the
          meantime, exploratory and in-progress material lives in the{' '}
          <a href={withBase('/notebook/')} class="text-accent underline underline-offset-2">
            notebook
          </a>
          .
        </li>
      )
    }
  </ol>
</AcademicLayout>

---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { withBase } from '../lib/paths';
import { SITE, NAV } from '../lib/site';
---

<AcademicLayout
  title={`Page not found — ${SITE.name}`}
  description="The page you were looking for does not exist."
  noindex={true}
>
  <section class="mx-auto max-w-2xl py-10">
    <p class="font-mono text-xs uppercase tracking-wide text-accent">Error 404</p>
    <h1 class="mt-2 font-serif text-2xl font-normal text-ink">Page not found</h1>
    <p class="mt-4 text-ink/80">
      The page you were looking for doesn't exist or has moved. These might help:
    </p>
    <ul class="mt-4 space-y-2">
      {
        NAV.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              class="text-accent underline underline-offset-2 hover:text-ink"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</AcademicLayout>

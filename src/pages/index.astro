---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/paths';

const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featuredPapers = papers.slice(0, 3);

const notebookEntries = (await getCollection('notebook')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const recentEntries = notebookEntries.slice(0, 5);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<AcademicLayout title="Research Notebook — Rafa Fuentes">
  <section class="max-w-2xl">
    <h1 class="font-serif text-3xl font-normal text-ink">Rafa Fuentes</h1>
    <p class="mt-2 font-mono text-sm text-ink/60">AI Research &middot; Notes &middot; Preprints</p>
    <p class="mt-6 text-lg leading-relaxed text-ink/90">
      I work on efficiency and alignment problems in large language models —
      currently focused on sparse attention mechanisms for long-context
      inference and curriculum design for RLHF fine-tuning. This site is a
      running notebook: preprints on the left, working notes on the right,
      and not much distinction in rigor between the two.
    </p>
  </section>

  <section class="mt-12 max-w-2xl">
    <h2 class="font-mono text-xs uppercase tracking-wide text-accent">Current AI Focus</h2>
    <ul class="mt-3 space-y-2 text-ink/85">
      <li>Sub-quadratic attention routing for 100k+ token contexts.</li>
      <li>Sample-efficient curricula for RL-based alignment fine-tuning.</li>
      <li>Evaluation methodology for long-context claims.</li>
    </ul>
  </section>

  <section class="mt-14 grid gap-12 lg:grid-cols-2">
    <div>
      <div class="flex items-baseline justify-between border-b border-ink/10 pb-2">
        <h2 class="font-mono text-xs uppercase tracking-wide text-accent">Featured Preprints</h2>
        <a href={withBase('/papers')} class="font-mono text-xs text-ink/50 hover:text-accent">all papers &rarr;</a>
      </div>
      <ul class="mt-4 space-y-6">
        {
          featuredPapers.map((paper) => (
            <li>
              <a href={withBase(`/papers#${paper.id}`)} class="font-serif text-base text-ink hover:text-accent">
                {paper.data.title}
              </a>
              <p class="mt-1 font-mono text-xs text-ink/50">
                {paper.data.venue} &middot; {dateFormatter.format(paper.data.date)}
              </p>
            </li>
          ))
        }
        {featuredPapers.length === 0 && <p class="text-sm text-ink/50">No papers yet.</p>}
      </ul>
    </div>

    <div>
      <div class="flex items-baseline justify-between border-b border-ink/10 pb-2">
        <h2 class="font-mono text-xs uppercase tracking-wide text-accent">Notebook Log</h2>
        <a href={withBase('/notebook')} class="font-mono text-xs text-ink/50 hover:text-accent">all entries &rarr;</a>
      </div>
      <ul class="mt-4 space-y-6">
        {
          recentEntries.map((entry) => (
            <li>
              <a href={withBase(`/notebook/${entry.id}`)} class="font-serif text-base text-ink hover:text-accent">
                {entry.data.title}
              </a>
              <p class="mt-1 font-mono text-xs text-ink/50">{dateFormatter.format(entry.data.date)}</p>
              <p class="mt-1 text-sm text-ink/70">{entry.data.summary}</p>
            </li>
          ))
        }
        {recentEntries.length === 0 && <p class="text-sm text-ink/50">No entries yet.</p>}
      </ul>
    </div>
  </section>
</AcademicLayout>

---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/paths';
import { SITE, SOCIAL, RESEARCH_STATUS_LABELS, dateFormatter } from '../lib/site';
import { websiteJsonLd, profilePageJsonLd } from '../lib/jsonld';

const research = (await getCollection('research', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const notebook = (await getCollection('notebook', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const selectedResearch = research.slice(0, 3);
const selectedProjects = projects.slice(0, 3);
const latestNotebook = notebook.slice(0, 3);

const startHere = [
  research[0] && {
    label: 'A research note',
    href: `/research/${research[0].id}/`,
    title: research[0].data.title
  },
  projects[0] && {
    label: 'An engineering project',
    href: `/projects/${projects[0].id}/`,
    title: projects[0].data.title
  },
  notebook[0] && {
    label: 'The working notebook',
    href: '/notebook/',
    title: 'Exploratory notes and early ideas'
  }
].filter((x) => x != null);
---

<AcademicLayout
  title={SITE.title}
  description={SITE.description}
  ogType="profile"
  jsonLd={[profilePageJsonLd(), websiteJsonLd()]}
>
  <!-- Hero -->
  <section class="max-w-2xl">
    <h1 class="font-serif text-3xl font-normal text-ink">Rafael Fuentes Rangel</h1>
    <p class="mt-2 font-mono text-sm text-ink/70">Software Engineer &middot; ML/AI Engineer</p>
    <p class="mt-6 text-lg leading-relaxed text-ink/90">
      I build production-oriented AI systems and agentic workflows, and I
      explore problems at the intersection of machine learning, software
      engineering, mathematics, and scientific research. This site collects
      my research notes, engineering projects, and a working notebook.
    </p>
    <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs">
      <li><a href={SOCIAL.github} rel="me" class="text-accent underline underline-offset-2 hover:text-ink">GitHub</a></li>
      <li><a href={SOCIAL.x} rel="me" class="text-accent underline underline-offset-2 hover:text-ink">X</a></li>
      <li><a href={`mailto:${SOCIAL.email}`} class="text-accent underline underline-offset-2 hover:text-ink">Email</a></li>
      <li><a href={withBase('/about/')} class="text-accent underline underline-offset-2 hover:text-ink">About &rarr;</a></li>
    </ul>
  </section>

  <!-- Current focus -->
  <section class="mt-12 max-w-2xl" aria-labelledby="focus-heading">
    <h2 id="focus-heading" class="font-mono text-xs uppercase tracking-wide text-accent">
      Current Focus
    </h2>
    <ul class="mt-3 space-y-2 text-ink/85">
      <li>Production ML/AI systems and agentic workflows.</li>
      <li>Mathematics and scientific computing as engineering tools.</li>
      <li>Research tooling: making experiments reproducible and legible.</li>
    </ul>
  </section>

  <!-- Selected research + projects: sections render only once real
       content exists, so the homepage never shows placeholder apologies. -->
  {
    (selectedResearch.length > 0 || selectedProjects.length > 0) && (
      <section class="mt-14 grid gap-12 lg:grid-cols-2">
        {selectedResearch.length > 0 && (
          <div aria-labelledby="research-heading">
            <div class="flex items-baseline justify-between border-b border-ink/10 pb-2">
              <h2
                id="research-heading"
                class="font-mono text-xs uppercase tracking-wide text-accent"
              >
                Selected Research
              </h2>
              <a
                href={withBase('/research/')}
                class="font-mono text-xs text-ink/60 hover:text-accent"
              >
                all research &rarr;
              </a>
            </div>
            <ul class="mt-4 space-y-6">
              {selectedResearch.map((item) => (
                <li>
                  <a
                    href={withBase(`/research/${item.id}/`)}
                    class="font-serif text-base text-ink hover:text-accent"
                  >
                    {item.data.title}
                  </a>
                  <p class="mt-1 font-mono text-xs text-ink/60">
                    {RESEARCH_STATUS_LABELS[item.data.status]} &middot;{' '}
                    {dateFormatter.format(item.data.date)}
                  </p>
                </li>
              ))}
            </ul>
          </div>
        )}

        {selectedProjects.length > 0 && (
          <div aria-labelledby="projects-heading">
            <div class="flex items-baseline justify-between border-b border-ink/10 pb-2">
              <h2
                id="projects-heading"
                class="font-mono text-xs uppercase tracking-wide text-accent"
              >
                Selected Projects
              </h2>
              <a
                href={withBase('/projects/')}
                class="font-mono text-xs text-ink/60 hover:text-accent"
              >
                all projects &rarr;
              </a>
            </div>
            <ul class="mt-4 space-y-6">
              {selectedProjects.map((project) => (
                <li>
                  <a
                    href={withBase(`/projects/${project.id}/`)}
                    class="font-serif text-base text-ink hover:text-accent"
                  >
                    {project.data.title}
                  </a>
                  <p class="mt-1 font-mono text-xs text-ink/60">
                    {dateFormatter.format(project.data.date)}
                  </p>
                  <p class="mt-1 text-sm text-ink/70">{project.data.summary}</p>
                </li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )
  }

  <!-- Notebook log: hidden until there are real entries, matching the
       research/projects sections above. -->
  {
    latestNotebook.length > 0 && (
      <section class="mt-14 grid gap-12 lg:grid-cols-2">
        <div aria-labelledby="notebook-heading">
          <div class="flex items-baseline justify-between border-b border-ink/10 pb-2">
            <h2 id="notebook-heading" class="font-mono text-xs uppercase tracking-wide text-accent">
              Notebook Log
            </h2>
            <a href={withBase('/notebook/')} class="font-mono text-xs text-ink/60 hover:text-accent"
              >all entries &rarr;</a
            >
          </div>
          <ul class="mt-4 space-y-6">
            {latestNotebook.map((entry) => (
              <li>
                <a
                  href={withBase(`/notebook/${entry.id}/`)}
                  class="font-serif text-base text-ink hover:text-accent"
                >
                  {entry.data.title}
                </a>
                <p class="mt-1 font-mono text-xs text-ink/60">
                  {dateFormatter.format(entry.data.date)}
                </p>
                <p class="mt-1 text-sm text-ink/70">{entry.data.summary}</p>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Start here: only worth showing once there is more than one entry point. -->
  {startHere.length >= 2 && (
  <section class="mt-14 max-w-2xl border-t border-ink/10 pt-8" aria-labelledby="start-heading">
    <h2 id="start-heading" class="font-mono text-xs uppercase tracking-wide text-accent">
      Start Here
    </h2>
    <p class="mt-3 text-sm text-ink/70">New to the site? These are good entry points:</p>
    <ul class="mt-4 space-y-3">
      {
        startHere.map((item) => (
          <li class="flex flex-wrap items-baseline gap-x-3">
            <span class="font-mono text-xs text-ink/60">{item.label}</span>
            <a
              href={withBase(item.href)}
              class="font-serif text-base text-accent underline underline-offset-2 hover:text-ink"
            >
              {item.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
  )}
</AcademicLayout>

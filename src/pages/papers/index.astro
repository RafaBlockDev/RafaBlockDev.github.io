---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';

const papers = (await getCollection('papers')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<AcademicLayout title="Papers — Research Notebook" description="Preprints and papers.">
  <h1 class="font-serif text-2xl font-normal text-ink">Papers</h1>
  <p class="mt-2 max-w-2xl text-sm text-ink/60">
    Preprints, workshop papers, and works in progress, newest first.
  </p>

  <ol class="mt-10 max-w-3xl space-y-10">
    {
      papers.map((paper, index) => (
        <li id={paper.id} class="scroll-mt-24 border-b border-ink/10 pb-8 last:border-none">
          <div class="flex items-start gap-3">
            <span class="mt-1 font-mono text-xs text-ink/40">[{index + 1}]</span>
            <div class="flex-1">
              <h2 class="font-serif text-lg text-ink">{paper.data.title}</h2>
              <p class="mt-1 text-sm text-ink/70">{paper.data.authors.join(', ')}</p>
              <p class="mt-1 font-mono text-xs text-ink/50">
                {paper.data.venue} &middot; {dateFormatter.format(paper.data.date)}
                {paper.data.arxivId && <> &middot; arXiv:{paper.data.arxivId}</>}
              </p>

              <div class="mt-3 flex flex-wrap gap-2">
                {paper.data.tags.map((tag) => (
                  <span class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-4 flex flex-wrap items-center gap-4 font-mono text-xs">
                {paper.data.pdfUrl && (
                  <a href={paper.data.pdfUrl} class="text-accent underline underline-offset-2 hover:text-ink">
                    PDF
                  </a>
                )}
                {paper.data.codeUrl && (
                  <a href={paper.data.codeUrl} class="text-accent underline underline-offset-2 hover:text-ink">
                    Code
                  </a>
                )}
                {paper.data.arxivId && (
                  <a
                    href={`https://arxiv.org/abs/${paper.data.arxivId}`}
                    class="text-accent underline underline-offset-2 hover:text-ink"
                  >
                    arXiv
                  </a>
                )}
              </div>

              <details class="mt-4 group">
                <summary class="cursor-pointer font-mono text-xs uppercase tracking-wide text-ink/60 group-open:text-accent">
                  Abstract
                </summary>
                <p class="mt-2 text-sm leading-relaxed text-ink/80">{paper.data.abstract}</p>
              </details>

              {paper.data.bibtex && (
                <details class="mt-3 group">
                  <summary class="cursor-pointer font-mono text-xs uppercase tracking-wide text-ink/60 group-open:text-accent">
                    BibTeX
                  </summary>
                  <div class="relative mt-2">
                    <pre
                      class="overflow-x-auto rounded-sm border border-ink/10 bg-ink/5 p-3 font-mono text-xs leading-relaxed text-ink/80"
                    ><code>{paper.data.bibtex}</code></pre>
                    <button
                      type="button"
                      class="bibtex-copy absolute top-2 right-2 rounded-sm border border-ink/20 bg-paper px-2 py-1 font-mono text-[0.65rem] text-ink/70 hover:border-accent hover:text-accent"
                      data-bibtex={paper.data.bibtex}
                    >
                      Copy
                    </button>
                  </div>
                </details>
              )}
            </div>
          </div>
        </li>
      ))
    }
    {papers.length === 0 && <p class="text-sm text-ink/50">No papers yet.</p>}
  </ol>
</AcademicLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('.bibtex-copy').forEach((button) => {
    button.addEventListener('click', async () => {
      const bibtex = button.dataset.bibtex ?? '';
      try {
        await navigator.clipboard.writeText(bibtex);
        const original = button.textContent;
        button.textContent = 'Copied';
        setTimeout(() => {
          button.textContent = original;
        }, 1500);
      } catch {
        // Clipboard API unavailable; no-op.
      }
    });
  });
</script>

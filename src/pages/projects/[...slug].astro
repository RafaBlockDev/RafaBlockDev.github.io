---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { SITE, dateFormatter } from '../../lib/site';
import { softwareJsonLd, breadcrumbJsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects/' },
  { label: data.title }
];

const pageUrl = new URL(Astro.url.pathname, SITE.url).href;
const jsonLd = [
  softwareJsonLd({
    title: data.title,
    description: data.summary,
    url: pageUrl,
    repoUrl: data.repoUrl
  }),
  breadcrumbJsonLd(crumbs)
];
---

<AcademicLayout
  title={`${data.title} · ${SITE.name}`}
  description={data.summary}
  ogType="article"
  ogImage={data.ogImage}
  publishedTime={data.date}
  modifiedTime={data.updatedDate}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-2xl">
    <Breadcrumbs crumbs={crumbs} />

    <header class="mt-6">
      <p class="font-mono text-xs uppercase tracking-wide text-accent">Project</p>
      <h1 class="mt-2 font-serif text-2xl font-normal leading-snug text-ink">{data.title}</h1>
      <p class="mt-3 text-sm leading-relaxed text-ink/80">{data.summary}</p>
      <p class="mt-2 font-mono text-xs text-ink/60">
        {dateFormatter.format(data.date)}
        {data.updatedDate && <> &middot; updated {dateFormatter.format(data.updatedDate)}</>}
        {data.role && <> &middot; {data.role}</>}
      </p>
      {
        data.stack.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2" aria-label="Stack">
            {data.stack.map((tool) => (
              <li class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">
                {tool}
              </li>
            ))}
          </ul>
        )
      }
      {
        (data.repoUrl || data.demoUrl) && (
          <ul class="mt-4 flex flex-wrap items-center gap-4 font-mono text-xs" aria-label="Links">
            {data.repoUrl && (
              <li>
                <a href={data.repoUrl} class="text-accent underline underline-offset-2 hover:text-ink">
                  Repository
                </a>
              </li>
            )}
            {data.demoUrl && (
              <li>
                <a href={data.demoUrl} class="text-accent underline underline-offset-2 hover:text-ink">
                  Live site
                </a>
              </li>
            )}
          </ul>
        )
      }
    </header>

    <div class="prose-doc mt-8 max-w-none">
      <Content />
    </div>
  </article>
</AcademicLayout>

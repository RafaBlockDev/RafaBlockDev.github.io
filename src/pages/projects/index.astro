---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import PillList from '../../components/PillList.astro';
import { getSortedCollection } from '../../lib/content';
import { withBase } from '../../lib/paths';
import { SITE, dateFormatter } from '../../lib/site';
import { breadcrumbJsonLd } from '../../lib/jsonld';

const projects = await getSortedCollection('projects');
---

<AcademicLayout
  title={`Projects · ${SITE.name}`}
  description="Engineering projects by Rafael Fuentes Rangel: AI/ML systems, agentic workflows, and developer tools."
  jsonLd={[breadcrumbJsonLd([{ label: 'Home', href: '/' }, { label: 'Projects' }])]}
>
  <h1 class="font-serif text-2xl font-normal text-ink">Projects</h1>
  <p class="mt-2 max-w-2xl text-sm text-ink/70">
    Engineering work with usable implementations: AI/ML systems, agentic
    workflows, and developer tools.
  </p>

  <ol class="mt-10 max-w-3xl space-y-10">
    {
      projects.map((project) => (
        <li class="border-b border-ink/10 pb-8 last:border-none">
          <h2 class="font-serif text-lg text-ink">
            <a href={withBase(`/projects/${project.id}/`)} class="hover:text-accent">
              {project.data.title}
            </a>
          </h2>
          <p class="mt-1 font-mono text-xs text-ink/60">
            {dateFormatter.format(project.data.date)}
            {project.data.role && <> &middot; {project.data.role}</>}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-ink/80">{project.data.summary}</p>
          <PillList items={project.data.stack} label="Stack" class="mt-3" />
          <p class="mt-3">
            <a
              href={withBase(`/projects/${project.id}/`)}
              class="font-mono text-xs text-accent underline underline-offset-2 hover:text-ink"
            >
              Case study &rarr;
            </a>
          </p>
        </li>
      ))
    }
    {
      projects.length === 0 && (
        <li class="max-w-2xl text-sm leading-relaxed text-ink/70">
          Project write-ups are in progress.
        </li>
      )
    }
  </ol>
</AcademicLayout>

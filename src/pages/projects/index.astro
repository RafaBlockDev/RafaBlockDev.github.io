---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/paths';
import { SITE, SOCIAL, dateFormatter } from '../../lib/site';
import { breadcrumbJsonLd } from '../../lib/jsonld';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<AcademicLayout
  title={`Projects · ${SITE.name}`}
  description="Engineering projects by Rafael Fuentes Rangel: AI/ML systems, agentic workflows, developer tools, and open-source work."
  jsonLd={[breadcrumbJsonLd([{ label: 'Home', href: '/' }, { label: 'Projects' }])]}
>
  <h1 class="font-serif text-2xl font-normal text-ink">Projects</h1>
  <p class="mt-2 max-w-2xl text-sm text-ink/70">
    Engineering work with usable implementations: AI/ML systems, agentic
    workflows, developer tools, and open-source repositories. More is on{' '}
    <a href={SOCIAL.github} class="text-accent underline underline-offset-2 hover:text-ink"
      >GitHub</a
    >.
  </p>

  <ol class="mt-10 max-w-3xl space-y-10">
    {
      projects.map((project) => (
        <li class="border-b border-ink/10 pb-8 last:border-none">
          <h2 class="font-serif text-lg text-ink">
            <a href={withBase(`/projects/${project.id}/`)} class="hover:text-accent">
              {project.data.title}
            </a>
          </h2>
          <p class="mt-1 font-mono text-xs text-ink/60">
            {dateFormatter.format(project.data.date)}
            {project.data.role && <> &middot; {project.data.role}</>}
          </p>
          <p class="mt-2 text-sm leading-relaxed text-ink/80">{project.data.summary}</p>
          {project.data.stack.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-2" aria-label="Stack">
              {project.data.stack.map((tool) => (
                <li class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">
                  {tool}
                </li>
              ))}
            </ul>
          )}
          <p class="mt-3">
            <a
              href={withBase(`/projects/${project.id}/`)}
              class="font-mono text-xs text-accent underline underline-offset-2 hover:text-ink"
            >
              Case study &rarr;
            </a>
          </p>
        </li>
      ))
    }
    {
      projects.length === 0 && (
        <li class="max-w-2xl text-sm leading-relaxed text-ink/70">
          Project write-ups are in progress. In the meantime, public code lives
          on{' '}
          <a href={SOCIAL.github} class="text-accent underline underline-offset-2">
            GitHub
          </a>
          .
        </li>
      )
    }
  </ol>
</AcademicLayout>

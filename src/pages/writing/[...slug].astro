---
import AcademicLayout from '../../layouts/AcademicLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { SITE, dateFormatter } from '../../lib/site';
import { articleJsonLd, breadcrumbJsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

interface Props {
  post: CollectionEntry<'writing'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Writing', href: '/writing' },
  { label: data.title }
];

const pageUrl = new URL(Astro.url.pathname, SITE.url).href;
const jsonLd = [
  articleJsonLd({
    type: 'BlogPosting',
    title: data.title,
    description: data.summary,
    url: pageUrl,
    datePublished: data.date,
    dateModified: data.updatedDate
  }),
  breadcrumbJsonLd(crumbs)
];
---

<AcademicLayout
  title={`${data.title} · ${SITE.name}`}
  description={data.summary}
  ogType="article"
  ogImage={data.ogImage}
  publishedTime={data.date}
  modifiedTime={data.updatedDate}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-2xl">
    <Breadcrumbs crumbs={crumbs} />

    <header class="mt-6">
      <h1 class="font-serif text-2xl font-normal leading-snug text-ink">{data.title}</h1>
      <p class="mt-2 font-mono text-xs text-ink/60">
        {dateFormatter.format(data.date)}
        {data.updatedDate && <> &middot; updated {dateFormatter.format(data.updatedDate)}</>}
      </p>
      {
        data.tags.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2" aria-label="Tags">
            {data.tags.map((tag) => (
              <li class="rounded-sm bg-accent/5 px-2 py-0.5 font-mono text-[0.65rem] text-accent">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose-doc mt-8 max-w-none">
      <Content />
    </div>
  </article>
</AcademicLayout>

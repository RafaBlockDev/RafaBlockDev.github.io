---
import Analytics from '@vercel/analytics/astro'
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RafaBlockDev | Software Engineer | Blockchain × AI',
  description = 'Building autonomous agents that actually make money on-chain. From Mexico City to the world.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <Analytics />
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@rafablockdev" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-mono/style.min.css"
    />

    <ViewTransitions />
  </head>
  <body class="bg-black text-[#ededed] font-sans antialiased overflow-x-hidden">
    <slot />

    <script is:inline>
      console.log('%c¡Órale! 🌮', 'font-size: 20px; font-weight: bold;');
      console.log('%cIf you can read this, we should probably work together.', 'font-size: 12px; color: #22c55e;');
      console.log('%cDM me: @rafablockdev', 'font-size: 12px; color: #888;');
    </script>
  </body>
</html>

---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { withBase } from '../lib/paths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'An academic AI research notebook: papers, notes, and works in progress.' } = Astro.props;

const nav = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/papers'), label: 'Papers' },
  { href: withBase('/notebook'), label: 'Notebook' }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-paper font-serif text-ink antialiased">
    <header class="border-b border-ink/10">
      <div class="mx-auto flex max-w-[78rem] flex-wrap items-baseline justify-between gap-x-8 gap-y-2 px-6 py-6">
        <a href={withBase('/')} class="font-mono text-sm tracking-tight text-ink">
          <span class="text-accent">&gt;</span> research notebook
        </a>
        <nav class="flex gap-6 font-mono text-xs uppercase tracking-wide text-ink/70">
          {
            nav.map((item) => (
              <a href={item.href} class="transition-colors hover:text-accent">
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-[78rem] px-6 py-10">
      <slot />
    </main>

    <footer class="mt-16 border-t border-ink/10">
      <div class="mx-auto max-w-[78rem] px-6 py-8 font-mono text-xs text-ink/50">
        <p>Updated continuously. Views and errors are my own.</p>
      </div>
    </footer>
  </body>
</html>
